{
    "log": {
        "access": "{{log_access}}",
        "error": "{{log_error}}",
        "loglevel": "{{loglevel}}"
    },
    "inbounds": [
        {%- set ns = namespace(first=true) -%}
        {%- for s in shadowsocks -%}
        {%- if not ns.first -%}
        ,
        {% endif %}
            {
                "tag":"{{s.tag}}",
                "protocol": "shadowsocks",
                "port": {{s.port}},
                "settings": {
                    "method": "{{s.cipher}}",
                    "password": "{{s.password}}",
                    "udp": {{s.udp | lower}},
                    "network": "tcp,udp",
                    "level": 0,
                    "ota": false
                }
            }
        {%- set ns.first = false -%}
        {%- endfor -%}
        {%- if not ns.first -%},{%- endif %}
        {
            "tag": "vmess",
            "port": {{vmess[0].port if vmess else 0}},
            "protocol": "vmess",
            "settings": {
                "clients": [
                {%- for s in vmess -%}
                    {%- if loop.index != 1 -%},{%- endif %}
                    {
                        "email": "{{s.tag}}",
                        "id": "{{s.uuid}}",
                        "alterId": {{s.alterId}}
                    }
                {%- endfor %}
                ]
            },
            "streamSettings": {
                "network": "{{vmess[0].network if vmess else 'raw'}}"
            }
        }
        {%- set ns.first = false -%}
        {%- for s in http -%}
            {%- if not ns.first -%},{%- endif %}
            {
                "tag": "{{s.tag}}",
                "protocol": "http",
                "port": {{s.port}},
                "settings": {
                    {%- if s.username %}
                        "accounts": [
                            {
                                "user": "{{s.username}}",
                                "pass": "{{s.password}}"
                            }
                        ],
                    {%- endif %}
                    "timeout": 0,
                    "userLevel": 0,
                    "allowTransparent": false
                },
                "sniffing": {
                    "enabled": true,
                    "destOverride": [
                        "http",
                        "tls"
                    ]
                }
            }
            {%- set ns.first = false -%}
        {%- endfor -%}
        {%- for s in socks5 -%}
            {%- if not ns.first -%},{%- endif %}
            {
                "tag":"{{s.tag}}",
                "protocol": "socks",
                "port": {{s.port}},
                "settings": {
                    "udp": {{s.udp | lower}},
                    "auth": "{{s.auth}}",
                    {%- if s.username %}
                    "accounts": [
                        {
                            "user": "{{s.username}}",
                            "pass": "{{s.password}}"
                        }
                    ],
                    {%- endif %}
                    "userLevel": 0,
                    "ip": "0.0.0.0"
                },
                "sniffing": {
                    "enabled": true,
                    "destOverride": [
                        "http",
                        "tls"
                    ]
                }
            }
            {%- set ns.first = false -%}
        {%- endfor %}
    ],
    "outbounds": [{
        {%- if (outbound.protocol=="socks" or outbound.protocol=="http") %}
        "protocol": "{{outbound.protocol}}",
        "settings": {
            "servers": [
                {
                    "address": "{{outbound.server}}",
                    "port": {{outbound.port}}
                    {%- if outbound.auth=="password" %}
                    ,"users":[
                        {
                            "user":"{{outbound.username}}",
                            "pass":"{{outbound.password}}"
                        }
                    ]
                    {%- endif %}
                }
            ]
        },
        "streamSettings": {
            "sockopt": {
                "note":"for transparent proxy",
                "mark": 255
            }
        }

        {%- elif outbound.protocol=="vless" %}
        "protocol": "{{outbound.protocol}}",
        "settings":{
            "vnext":[
                {
                    "address":"{{outbound.server}}",
                    "port": {{outbound.port}},
                    "users": [
                        {
                            "id": "{{outbound.uuid}}",
                            "flow": "{{outbound.flow}}",
                            "encryption": "{{outbound.encryption}}",
                            "level": {{outbound.level}}
                        }
                    ]
                }
            ]
        },
        "streamSettings":{
            "network": "{{outbound.network}}",
            "security": "{{outbound.security}}",
            "xtlsSettings":{
                "serverName": "{{outbound.server}}"
            }
        }
        {%- elif outbound.protocol == "file" %}
        {{outbound.file}}

        {%- endif %}
    }],
    "api": {
        "tag": "api",
        "listen": "127.0.0.1:{{api_port}}",
        "services": [
            "StatsService"
        ]
    },
    "stats": {},
    "policy": {
        "levels": {
            "0": {
                "statsUserUplink": true,
                "statsUserDownlink": true
            }
        },
        "system": {
            "statsInboundUplink": true,
            "statsInboundDownlink": true,
            "statsOutboundUplink": true,
            "statsOutboundDownlink": true
        }
    }
}
